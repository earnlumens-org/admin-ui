# Copy this file to `.env.development.local` (or set vars in your hosting)
# Vite exposes only variables prefixed with VITE_

# Base URL for admin backend API
# If left empty, the app auto-detects based on hostname:
#   - localhost / 127.0.0.1           -> http://localhost:8082
#   - admin-dev.earnlumens.org        -> https://admin-api-dev.earnlumens.org
#   - admin.earnlumens.org            -> https://admin-api.earnlumens.org
# Set this only if you need to override the auto-detection.
VITE_API_BASE_URL=
